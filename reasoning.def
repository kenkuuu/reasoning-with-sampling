Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

%files
    . /workspace

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        software-properties-common \
        build-essential \
        pkg-config \
        curl \
        git \
        libcairo2-dev \
        libpango1.0-dev \
        libglib2.0-dev \
        libgl1 \
        libegl1 \
        libunwind-dev \
        ffmpeg \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
        python3.12 \
        python3.12-dev \
        python3.12-venv \
    && rm -rf /var/lib/apt/lists/*

    # pip → uv
    python3.12 -m ensurepip --upgrade
    python3.12 -m pip install uv --quiet

    # 仮想環境
    uv venv /opt/venv --python python3.12
    export PATH="/opt/venv/bin:$PATH"

    # torch: PyPI から（CUDA は nvidia-* パッケージ経由）
    uv pip install --no-cache \
        torch==2.8.0 \
        torchvision==0.23.0 \
        triton==3.4.0

    # xformers は torch==2.5.1 を要求するが元環境も無視してインストール済み
    uv pip install --no-cache --no-deps xformers==0.0.28.post3

    # 残りのパッケージ
    uv pip install --no-cache -r /workspace/requirements.txt

%environment
    export PATH="/opt/venv/bin:$PATH"
    export PYTHONPATH=/workspace/llm_experiments:$PYTHONPATH
    export VIRTUAL_ENV=/opt/venv

%runscript
    cd /workspace/llm_experiments
    exec python "$@"
