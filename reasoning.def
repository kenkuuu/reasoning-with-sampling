Bootstrap: docker
From: pytorch/pytorch:2.6.0-cuda12.4-cudnn9-runtime

%files
    . /workspace

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        pkg-config \
        curl \
        git \
        libcairo2-dev \
        libpango1.0-dev \
        libglib2.0-dev \
        libgl1 \
        libegl1 \
        libunwind-dev \
        ffmpeg \
    && rm -rf /var/lib/apt/lists/*

    # uv（base image の conda Python に対してインストール）
    pip install uv --quiet --root-user-action=ignore

    # torchvision: torch 2.6.0 互換版（base image に torch は含まれているが torchvision は含まれない）
    CONDA_PYTHON=/opt/conda/bin/python

    uv pip install --python ${CONDA_PYTHON} --no-cache torchvision==0.21.0

    # xformers: torch 依存の制約を無視してインストール
    uv pip install --python ${CONDA_PYTHON} --no-cache --no-deps xformers==0.0.28.post3

    # torch/torchvision は base image のバージョンで固定（2.8.0 を要求するパッケージを上書き）
    cat > /tmp/overrides.txt << 'EOF'
torch==2.6.0
torchvision==0.21.0
numpy==2.2.6
EOF

    uv pip install --python ${CONDA_PYTHON} --no-cache \
        --override /tmp/overrides.txt \
        -r /workspace/requirements.txt

%environment
    export PYTHONPATH=/workspace/llm_experiments:$PYTHONPATH

%runscript
    cd /workspace/llm_experiments
    exec python "$@"
