Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

%files
    . /workspace

%post
    # System packages
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        software-properties-common \
        build-essential \
        pkg-config \
        git \
        libcairo2-dev \
        libpango1.0-dev \
        libglib2.0-dev \
        libgl1 \
        libunwind-dev \
        ffmpeg \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
        python3.12 \
        python3.12-dev \
        python3.12-venv \
    && rm -rf /var/lib/apt/lists/*

    # uv
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    # Python 仮想環境
    uv venv /opt/venv --python python3.12
    export PATH="/opt/venv/bin:$PATH"

    # パッケージインストール
    uv pip install --no-cache -r /workspace/requirements.txt

%environment
    export PATH="/opt/venv/bin:/root/.local/bin:$PATH"
    export PYTHONPATH=/workspace/llm_experiments:$PYTHONPATH
    export VIRTUAL_ENV=/opt/venv

%runscript
    cd /workspace/llm_experiments
    exec python "$@"
